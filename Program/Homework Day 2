    }
    static void For8_Solution()
    {
        Console.WriteLine("--- For8 ---");
        Console.Write("Введите целое число A: ");
        int a = int.Parse(Console.ReadLine());
        Console.Write("Введите целое число B (больше A): ");
        int b = int.Parse(Console.ReadLine());

        long product = 1; // Используем long, чтобы избежать переполнения для больших произведений
        for (int i = a; i <= b; i++)
        {
            product *= i;
        }
        Console.WriteLine($"Произведение чисел от {a} до {b}: {product}");
        Console.WriteLine("------------------------------");
    }
	    static void For9_Solution()
    {
        Console.WriteLine("--- For9 ---");
        Console.Write("Введите целое число A: ");
        int a = int.Parse(Console.ReadLine());
        Console.Write("Введите целое число B (больше A): ");
        int b = int.Parse(Console.ReadLine());

        long sumOfSquares = 0; // Используем long на случай больших чисел
        for (int i = a; i <= b; i++)
        {
            sumOfSquares += (long)i * i;
        }
        Console.WriteLine($"Сумма квадратов чисел от {a} до {b}: {sumOfSquares}");
        Console.WriteLine("------------------------------");
    }
    static void For10_Solution()
    {
        Console.WriteLine("--- For10 ---");
        Console.Write("Введите целое число N (> 0): ");
        int n = int.Parse(Console.ReadLine());

        double sum = 0.0;
        for (int i = 1; i <= n; i++)
        {
sum += 1.0 / i;
        }
        Console.WriteLine($"Сумма ряда: {sum:F4}");
        Console.WriteLine("------------------------------");
    }
