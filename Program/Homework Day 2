using System;

class Program
{
        static void For1_Solution()
    {
        Console.WriteLine("--- For1 ---");
        Console.Write("Введите целое число K: ");
        int k = int.Parse(Console.ReadLine());
        Console.Write("Введите целое число N (> 0): ");
        int n = int.Parse(Console.ReadLine());

        for (int i = 0; i < n; i++)
        {
            Console.WriteLine(k);
        }
        Console.WriteLine("------------------------------");
    }
	    static void For2_Solution()
    {
        Console.WriteLine("--- For2 ---");
        Console.Write("Введите целое число A: ");
        int a = int.Parse(Console.ReadLine());
        Console.Write("Введите целое число B (больше A): ");
        int b = int.Parse(Console.ReadLine());

        int count = 0;
        for (int i = a; i <= b; i++)
        {
            Console.WriteLine(i);
            count++;
        }
        Console.WriteLine($"Количество чисел: {count}");
        Console.WriteLine("------------------------------");
    }
    static void For3_Solution()
    {
        Console.WriteLine("--- For3 ---");
        Console.Write("Введите целое число A: ");
        int a = int.Parse(Console.ReadLine());
        Console.Write("Введите целое число B (больше A): ");
        int b = int.Parse(Console.ReadLine());

        int count = 0;
        for (int i = b - 1; i > a; i--)
        {
            Console.WriteLine(i);
            count++;
        }
Console.WriteLine($"Количество чисел: {count}");
        Console.WriteLine("------------------------------");
    }
	    static void For4_Solution()
    {
        Console.WriteLine("--- For4 ---");
        Console.Write("Введите цену 1 кг конфет: ");
