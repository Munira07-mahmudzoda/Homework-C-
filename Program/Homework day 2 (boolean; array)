class Program
{
    static void Array1_Solution()
    {
        Console.WriteLine("--- Array1 ---");
        Console.Write("Введите целое число N (> 0): ");
        int n = int.Parse(Console.ReadLine());

        int[] arr = new int[n];

        for (int i = 0; i < n; i++)
        {
            arr[i] = 2 * i + 1; // Формула для n-го нечетного числа (начиная с 1-го)
        }

        Console.WriteLine("Элементы массива:");
        foreach (int item in arr)
        {
            Console.Write($"{item} ");
        }
        Console.WriteLine(); // Переход на новую строку после вывода
    }
}
