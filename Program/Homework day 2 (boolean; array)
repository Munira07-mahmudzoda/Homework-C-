class Program
{
    static void Array9_Solution()
    {
        Console.WriteLine("--- Array9 ---");
        Console.Write("Введите количество элементов N: ");
        int n = int.Parse(Console.ReadLine());

        int[] arr = new int[n];
        Console.WriteLine("Введите элементы массива:");
        for (int i = 0; i < n; i++)
        {
            Console.Write($"Элемент {i} (индекс): ");
            arr[i] = int.Parse(Console.ReadLine());
        }

        Console.WriteLine("Элементы с четными индексами (по возрастанию индекса):");
        for (int i = 0; i < n; i += 2) // Начинаем с индекса 0 (первый элемент, четный индекс)
        {
            Console.Write($"{arr[i]} ");
        }
        Console.WriteLine();

        Console.WriteLine("Элементы с нечетными индексами (по убыванию индекса):");
        // Находим последний нечетный индекс.
        // Если N четное, последний индекс n-1 (нечетный).
        // Если N нечетное, последний индекс n-2 (нечетный).
        int lastOddIndex = n - 1;
        while (lastOddIndex >= 0 && lastOddIndex % 2 == 0) // Если последний индекс четный, идем к предыдущему
        {
            lastOddIndex--;
        }

        for (int i = lastOddIndex; i >= 0; i -= 2) // Идем назад с шагом 2
        {
            Console.Write($"{arr[i]} ");
        }
        Console.WriteLine();
        Console.WriteLine("------------------------------");
    }
}
