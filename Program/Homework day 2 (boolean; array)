class Program
{
    static void Array5_Solution()
    {
        Console.WriteLine("--- Array5 ---");
        Console.Write("Введите целое число N (> 2) для ряда Фибоначчи: ");
        int n = int.Parse(Console.ReadLine());

        if (n <= 2)
        {
            Console.WriteLine("N должно быть больше 2 для этой задачи.");
            Console.WriteLine("------------------------------");
            return;
        }

        int[] fibArray = new int[n];

        // Инициализация первых двух элементов по условию: f1 = 1, f2 = 1
        fibArray[0] = 1; // f1
        fibArray[1] = 1; // f2

        // Вычисление остальных элементов по формуле f_k = f_{k-2} + f_{k-1}
        for (int i = 2; i < n; i++)
        {
            fibArray[i] = fibArray[i - 1] + fibArray[i - 2];
        }

        Console.WriteLine("Элементы массива Фибоначчи:");
        foreach (int item in fibArray)
        {
            Console.Write($"{item} ");
        }
        Console.WriteLine();
        Console.WriteLine("------------------------------");
    }
}
