    static void Array6_Solution()
    {
        Console.WriteLine("--- Array6 ---");
        Console.Write("Введите целое число N (> 2): ");
        int n = int.Parse(Console.ReadLine());
        Console.Write("Введите целое число A (первый элемент): ");
        int a = int.Parse(Console.ReadLine());
        Console.Write("Введите целое число B (второй элемент): ");
        int b = int.Parse(Console.ReadLine());

        if (n <= 2)
        {
            Console.WriteLine("N должно быть больше 2 для этой задачи.");
            Console.WriteLine("------------------------------");
            return;
        }

        int[] arr = new int[n];
        arr[0] = a;
        arr[1] = b;
        long currentSum = a + b; // Используем long для суммы, так как она может быстро расти

        for (int i = 2; i < n; i++)
        {
            arr[i] = (int)currentSum; // Текущий элемент равен текущей сумме
            currentSum += arr[i];     // Обновляем сумму, добавляя новый элемент
        }

        Console.WriteLine("Элементы массива:");
        foreach (int item in arr)
        {
            Console.Write($"{item} ");
        }
        Console.WriteLine();
        Console.WriteLine("------------------------------");
    }
}
