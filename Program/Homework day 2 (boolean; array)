class Program
{
    static void Array8_Solution()
    {
        Console.WriteLine("--- Array8 ---");
        Console.Write("Введите количество элементов N: ");
        int n = int.Parse(Console.ReadLine());

        int[] arr = new int[n];
        Console.WriteLine("Введите элементы массива:");
        for (int i = 0; i < n; i++)
        {
            Console.Write($"Элемент {i} (индекс): ");
            arr[i] = int.Parse(Console.ReadLine());
        }

        Console.WriteLine("Элементы с нечетными индексами (по возрастанию индекса):");
        for (int i = 1; i < n; i += 2) // Начинаем с индекса 1 (второй элемент, нечетный индекс)
        {
            Console.Write($"{arr[i]} ");
        }
        Console.WriteLine();

        Console.WriteLine("Элементы с четными индексами (по убыванию индекса):");
        int startIndex = (n % 2 == 0) ? n - 2 : n - 1; // Определяем, с какого четного индекса начать.
                                                       // Если N четное, последний четный индекс N-2.
                                                       // Если N нечетное, последний четный индекс N-1.
                                                       // Но нам нужны только ЧЕТНЫЕ ИНДЕКСЫ, поэтому нужно
                                                       // найти ближайший четный индекс, не превышающий n-1
        
        // Более простой способ найти последний четный индекс:
        // Начать с n-1 и уменьшать, пока не найдем четный индекс.
        int lastEvenIndex = n - 1;
        while (lastEvenIndex >= 0 && lastEvenIndex % 2 != 0) // Если последний индекс нечетный, идем к предыдущему
        {
            lastEvenIndex--;
        }

        for (int i = lastEvenIndex; i >= 0; i -= 2) // Идем назад с шагом 2
        {
            Console.Write($"{arr[i]} ");
        }
        Console.WriteLine();
        Console.WriteLine("------------------------------");
    }
}
